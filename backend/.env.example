# ─── Database ──────────────────────────────────────────────────
DATABASE_URL="mysql://semsar:semsar_pass@localhost:3306/semsar_ai"
MYSQL_ROOT_PASSWORD=semsar_root
MYSQL_DATABASE=semsar_ai
MYSQL_USER=semsar
MYSQL_PASSWORD=semsar_pass

# ─── Gemini AI ─────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── WhatsApp Cloud API ───────────────────────────────────────
# Required in production. Get from Meta Developer Portal.
# See specs/004-whatsapp-production/spec.md for setup instructions.
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_APP_SECRET=your_app_secret_here
WHATSAPP_VERIFY_TOKEN=your_verify_token_here

# ─── WhatsApp OTP Template ────────────────────────────────────
# Pre-approved Meta template for OTP messages (Authentication category).
WHATSAPP_OTP_TEMPLATE_NAME=otp_verification
WHATSAPP_OTP_TEMPLATE_LANG=ar
# WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id_here

# ─── JWT Auth ──────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ─── App ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# In production, restrict CORS to your frontend domain(s), comma-separated.
# CORS_ORIGINS=https://semsar-ai.com,https://www.semsar-ai.com

# ─── SMS Fallback (optional) ──────────────────────────────────
# Enable SMS fallback when WhatsApp OTP delivery fails.
# SMS_FALLBACK_ENABLED=false
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxx
# TWILIO_PHONE_NUMBER=+20xxxxxxxxx
