MODEL_PATH=./model
BASE_MODEL=distilbert-base-multilingual-cased
PORT=8001
LOG_LEVEL=INFO
# When true, the service skips loading DistilBERT and relies on the stub classifier
# (regex + keyword heuristics). Useful for Phase A and when PyTorch weights aren't
# available locally.
USE_STUB_CLASSIFIER=true
CONFIDENCE_FLOOR=0.55
